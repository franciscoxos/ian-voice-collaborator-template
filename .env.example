# ═══════════════════════════════════════════════════════
# Colaborador Digital de Voz — Variables de entorno
# ═══════════════════════════════════════════════════════

# ── Supabase (REQUERIDO para todos) ──────────────────
SUPABASE_URL=                    # REQUERIDO — Settings > API > Project URL
SUPABASE_SERVICE_ROLE_KEY=       # REQUERIDO — Settings > API > service_role

# ── España: Telnyx (si tus contactos están en España) ─
TELNYX_API_KEY=                  # Mission Control > Auth > API Keys
TELNYX_TEXML_APP_ID=             # TeXML > Applications > tu app > ID
TELNYX_ASSISTANT_ID=             # AI Assistants > tu assistant > ID
TELNYX_FROM_NUMBER=              # Número fijo español aprobado (+34...)

# ── LATAM / USA: Vapi (si tus contactos están fuera de España) ─
VAPI_API_KEY=                    # Organization > API Keys
VAPI_PHONE_NUMBER_ID=            # Phone Numbers > tu número > UUID
VAPI_ASSISTANT_ID=               # AUTO-GENERADO por setup.sh

# ── Webhook (AUTO-GENERADO) ──────────────────────────
WEBHOOK_URL=                     # Se genera: {SUPABASE_URL}/functions/v1/vapi-webhook
